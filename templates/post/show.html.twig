{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}

<article class="article-card">
    <h1>{{ post.title }}</h1>
    <p>{{ post.content }}</p>
</article>

<hr>

{# 1. FORMULAIRE EN HAUT #}
<section class="comment-section">
    <h2>Ajouter un commentaire</h2>

    <div class="comment-form">
        {{ form_start(commentForm) }}
            {{ form_row(commentForm.username) }}
            {{ form_row(commentForm.content) }}
            <button type="submit" class="btn-submit">Envoyer</button>
        {{ form_end(commentForm) }}
    </div>

    <hr>

    {# 2. LISTE DES COMMENTAIRES EN BAS #}
    <h2>Commentaires</h2>

    <div class="comments-scroll-area">

        {% for comment in post.comments %}

            <div class="comment-box">
                <strong>{{ comment.username }}</strong>
                <small> le {{ comment.createdAt|date('d/m/Y à H:i') }}</small>

                <p>{{ comment.content|nl2br }}</p>
            </div>

        {% else %}

            <p>Aucun commentaire pour le moment. Soyez le premier !</p>

        {% endfor %}

    </div>

</section>

{% endblock %}