{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
    <article>
        <h1>{{ post.title }}</h1>
        
        <div class="post-content">
            {{ post.content|nl2br }}
        </div>

        <hr>

        <h3>Commentaires</h3>
        {% for comment in post.comments %}
            <div class="comment" style="border-bottom: 1px solid #eee; margin-bottom: 10px;">
                <p>{{ comment.content }}</p>
            </div>
        {% else %}
            <p>Aucun commentaire pour le moment.</p>
        {% endfor %}

        <hr>

        <h3>Laisser un commentaire</h3>
        {{ form_start(commentForm) }}
            {{ form_widget(commentForm) }}
            <button class="btn" style="background-color: #007bff; color: white; padding: 10px; border: none; cursor: pointer;">
                {{ button_label|default('Enregistrer') }}
            </button>
        {{ form_end(commentForm) }}

        <br>
        <a href="{{ path('app_post') }}">Retour à la liste</a>
    </article>
{% endblock %}